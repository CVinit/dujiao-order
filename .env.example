# dujiao-order environment variables

# Required: PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/dujiao_order?sslmode=disable

# Server listen address (default: ":8080")
LISTEN_ADDR=:8080

# Cloudflare Turnstile keys (leave empty to skip Turnstile verification)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Rate limiting (per-IP token bucket)
RATE_LIMIT_RPS=1
RATE_LIMIT_BURST=3

# Ban tracking (failed attempts before auto-ban)
BAN_THRESHOLD=10
BAN_DURATION=15m
