# dujiao-order environment variables

# --- Option A: docker-compose.yml (self-contained, includes its own PostgreSQL) ---
# Required: PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/dujiao_order?sslmode=disable

# --- Option B: docker-compose.external.yml (connect to existing PostgreSQL) ---
# These are used to construct DATABASE_URL in docker-compose.external.yml
PG_USER=dujiao
PG_PASSWORD=changeme
PG_HOST=shared-postgres

# Server listen address (default: ":8080")
LISTEN_ADDR=:8080

# Cloudflare Turnstile keys (leave empty to skip Turnstile verification)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Rate limiting (per-IP token bucket)
RATE_LIMIT_RPS=1
RATE_LIMIT_BURST=3

# Ban tracking (failed attempts before auto-ban)
BAN_THRESHOLD=10
BAN_DURATION=15m
